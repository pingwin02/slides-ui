{
  "name": "@pl.edu.pg.eti.kask/slides-ui",
  "version": "1.0.0",
  "displayName": "Slides UI",
  "description": "UI interface for slides in Markdown format.",
  "keywords": [
    "slides",
    "markdown"
  ],
  "author": {
    "name": "Michał (psysiu) Wójcik",
    "email": "michal.wojcik@eti.pg.edu.pl"
  },
  "license": "MIT",
  "scripts": {
    "init": "bash utils/create.sh",
    "delete": "bash utils/create.sh --delete",
    "start": "npm run serve",
    "serve": "bash utils/scan.sh && node server.js",
    "print": "bash utils/generate_pdf.sh",
    "backup": "bash utils/backup.sh",
    "restore": "bash utils/restore.sh",
    "lint": "eslint . --fix",
    "prelint": "prettier . --write"
  },
  "dependencies": {
    "decktape": "^3.15.0",
    "open": "^11.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1"
  }
}
